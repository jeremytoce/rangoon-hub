{
  "schemaVersion": 1,
  "name": "Wellness Starter",
  "description": "A wellness bundle: health coach steward with accountability skill and morning standup routine",
  "components": [
    { "type": "steward", "ref": "health-coach" },
    { "type": "skill", "ref": "accountability", "target_steward": "health-coach" },
    { "type": "routine", "ref": "morning-standup" }
  ],
  "mcp_servers": {
    "strava": {
      "package": "mcp-server-strava",
      "env_vars": ["STRAVA_CLIENT_ID", "STRAVA_CLIENT_SECRET", "STRAVA_REFRESH_TOKEN"]
    }
  },
  "config_overrides": {
    "cadence": "daily",
    "nudge_days": 2
  },
  "inputs": [
    {
      "id": "health-steps",
      "type": "mcp",
      "server": "strava",
      "tool": "get_activities"
    }
  ]
}
